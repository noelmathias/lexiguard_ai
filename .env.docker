# ── Application ─────────────────────────────────────────────
APP_NAME=Legal Intelligence System
VERSION=1.0.0
DEBUG=False
UPLOAD_DIR=data/uploads

# ── LLM ─────────────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b
LLM_FALLBACK_MODEL=qwen2.5:3b

# Points to the ollama service name inside Docker network
OLLAMA_BASE_URL=http://ollama:11434
LLM_TIMEOUT=90

# ── Keys ─────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Ollama container ─────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:3b

# ── Nginx ────────────────────────────────────────────────────
# For local dev — no domain needed
# For EC2 — set to your real domain
DOMAIN=localhost